# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
node_modules
.pnp
.pnp.js

# Local env files — .env.example é rastreado intencionalmente
.env
.env.docker.dev
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# Testing
coverage

# Turbo
.turbo

# Vercel
.vercel

# Build Outputs
.next/
out/
build
dist

# WhatsApp bot — sessão Baileys (credenciais locais)
apps/whatsapp-bot/data/*
!apps/whatsapp-bot/data/.gitkeep

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
.DS_Store
*.pem

deploy.log

.cursor/
.claude/
.agents/

# Uploads de usuário — arquivos de imagem não devem entrar no repositório
apps/public/images/users/*
apps/public/images/products/*
# Garante que os diretórios existam no clone (via .gitkeep)
!apps/public/images/users/.gitkeep
!apps/public/images/products/.gitkeep
