# ===========================================
# CONFIGURAÇÕES DA SICREDI - API DE COBRANÇA
# ===========================================

# Ambiente da SICREDI (homologation ou production)
SICREDI_ENVIRONMENT=homologation

# Credenciais da API SICREDI
SICREDI_CLIENT_ID=seu_client_id_sicredi
SICREDI_CLIENT_SECRET=seu_client_secret_sicredi

# Códigos da Cooperativa
SICREDI_COOPERATIVE_CODE=seu_codigo_cooperativa
SICREDI_POST_CODE=seu_codigo_posto

# Código de Acesso do Internet Banking
SICREDI_ACCESS_CODE=seu_codigo_acesso_internet_banking

# Token de Acesso para Requisições
SICREDI_ACCESS_TOKEN=seu_token_acesso_sicredi

# Sincronização Automática
SICREDI_AUTO_SYNC=true
SICREDI_SYNC_INTERVAL=30

# ===========================================
# CONFIGURAÇÕES OBRIGATÓRIAS DO SISTEMA
# ===========================================

# Ambiente da aplicação (development, production, test)
NODE_ENV=development

# Desliga rate limit em dev local (recomendado com Docker Desktop + npm run dev)
RATE_LIMIT_DISABLED=true

# Nível de log (error, warn, info, debug). Em produção default: info
# LOG_LEVEL=info

# Porta do Servidor
PORT=3333

# Swagger (produção): defina SWAGGER_ENABLED=true para expor; SWAGGER_SECRET opcional
# SWAGGER_ENABLED=false
# SWAGGER_SECRET=chave_secreta_para_acesso

# URL base da API (usada no Swagger e logs)
API_URL=http://localhost:3333

# URL do frontend (usada para links de reset de senha)
FRONTEND_URL=http://localhost:3000

# Banco de Dados MongoDB
MONGODB_URI=mongodb://localhost:27017/oticas-queiroz

# JWT Secret (gere uma chave segura com: openssl rand -base64 32)
JWT_SECRET=seu_jwt_secret_aqui

# Configurações de Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=seu_email@gmail.com
EMAIL_PASSWORD=sua_senha_email

# Configurações do Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=seu_access_token_mercado_pago
MERCADO_PAGO_PUBLIC_KEY=sua_public_key_mercado_pago
