# ============================================================
# Óticas Queiroz — variáveis de ambiente para Docker Compose
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no repositório.
# ============================================================

# --- MongoDB ---
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=troque-por-senha-forte-aqui

# --- Backend ---
JWT_SECRET=troque-por-string-aleatoria-minimo-32-chars
JWT_EXPIRES_IN=24h
FRONTEND_URL=https://app.oticasqueiroz.com.br
API_URL=https://app.oticasqueiroz.com.br/api

# --- Email (Nodemailer) ---
EMAIL_HOST=smtp.exemplo.com
EMAIL_PORT=587
EMAIL_USER=seuemail@exemplo.com
EMAIL_PASS=suasenha
EMAIL_FROM=noreply@oticasqueiroz.com.br

# --- Logging ---
LOG_LEVEL=info

# --- Swagger (em produção, mantenha SWAGGER_ENABLED=false) ---
SWAGGER_ENABLED=false
SWAGGER_SECRET=troque-por-chave-secreta

# --- SICREDI ---
SICREDI_ENVIRONMENT=production
SICREDI_CLIENT_ID=
SICREDI_CLIENT_SECRET=

# --- Mercado Pago ---
MERCADO_PAGO_ACCESS_TOKEN=

# --- Frontend ---
NEXT_PUBLIC_API_URL=https://app.oticasqueiroz.com.br/api

# --- Traefik (nome da rede externa já existente no VPS) ---
TRAEFIK_NETWORK=traefik-public
