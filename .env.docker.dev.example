# Variáveis só para docker-compose.dev.yml (infra local).
# Copie para .env.docker.dev na raiz do monorepo (arquivo ignorado pelo Git).
#
# Use a MESMA senha Mongo em apps/backend/.env → MONGODB_URI

MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=oticas_dev_local

# --- n8n (http://localhost:5678) ---
N8N_HOST=localhost
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo
