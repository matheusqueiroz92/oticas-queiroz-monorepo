# ─── Aplicação ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3344
LOG_LEVEL=debug

# ─── Autenticação (mesma chave do backend ERP) ───────────────────────────────
# Header x-api-key em POST /send-message
BOT_API_KEY=troque-por-chave-longa-e-aleatoria

# ─── n8n ─────────────────────────────────────────────────────────────────────
# IMPORTANTE: URL de *teste* (/webhook-test/...) só aceita 1 chamada por vez → 404 na 2ª mensagem.
# Em dev, use BOT_CHAT_MODE=erp OU URL de *produção* (/webhook/...) com workflow ATIVO.
N8N_WEBHOOK_URL=http://localhost:5678/webhook-test/oticas-queiroz
# N8N_WEBHOOK_URL=http://localhost:5678/webhook/oticas-queiroz
# N8N_WEBHOOK_URL=http://n8n:5678/webhook/oticas-queiroz
N8N_WEBHOOK_TIMEOUT_MS=10000

# ─── ERP Bot API (fallback ou modo direto) ───────────────────────────────────
ERP_API_URL=http://localhost:3333
# erp = sempre POST /api/bot/chat | n8n = webhook n8n (com fallback abaixo)
BOT_CHAT_MODE=n8n
# Se n8n falhar (404 após 1º teste) ou não devolver text, chama o ERP automaticamente
BOT_ERP_FALLBACK_ON_N8N_ERROR=true

# ─── WhatsApp (Baileys) ──────────────────────────────────────────────────────
WA_SESSION_PATH=./data/auth
WA_RECONNECT_DELAY_MS=3000
