# ============================================================
# Óticas Queiroz — variáveis de ambiente para Docker Compose
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no repositório.
# ============================================================

# --- MongoDB ---
# Produção (VPS): use o container/banco real — NÃO o mongodb embutido do compose
MONGODB_URI=mongodb://usuario:senha@oticas-queiroz-db:27017/oticas_queiroz_db?authSource=admin&replicaSet=rs0
# Rede Docker do container oticas-queiroz-db (docker inspect oticas-queiroz-db --format '{{range $k,$v := .NetworkSettings.Networks}}{{$k}}{{end}}')
MONGO_DOCKER_NETWORK=traefik-public
# Só para profile bundled-mongo (docker compose --profile bundled-mongo up)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=troque-por-senha-forte-aqui

# --- Backend ---
JWT_SECRET=troque-por-string-aleatoria-minimo-32-chars
JWT_EXPIRES_IN=24h
# Chave para rotas /api/bot e POST /send-message do whatsapp-bot (header x-api-key)
BOT_API_KEY=

# --- n8n (orquestrador de workflows) ---
N8N_HOST=localhost
# Base pública dos webhooks (navegador / URLs exibidas no editor n8n)
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo

# --- WhatsApp Bot (gateway) ---
# erp = resposta rápida direto no backend (recomendado em produção)
# n8n = só se tiver workflow publicado em /webhook/...
BOT_CHAT_MODE=erp
BOT_ERP_FALLBACK_ON_N8N_ERROR=true
N8N_WEBHOOK_TIMEOUT_MS=3000
# URL interna Docker: whatsapp-bot → n8n (path do Webhook em modo Produção)
N8N_WEBHOOK_URL=http://n8n:5678/webhook/whatsapp-inbound
FRONTEND_URL=https://app.oticasqueiroz.com.br
API_URL=https://api.app.oticasqueiroz.com.br

# --- Email (Nodemailer) ---
EMAIL_HOST=smtp.exemplo.com
EMAIL_PORT=587
EMAIL_USER=seuemail@exemplo.com
EMAIL_PASS=suasenha
EMAIL_FROM=noreply@oticasqueiroz.com.br

# --- Logging ---
LOG_LEVEL=info

# --- Swagger (em produção, mantenha SWAGGER_ENABLED=false) ---
SWAGGER_ENABLED=false
SWAGGER_SECRET=troque-por-chave-secreta

# --- SICREDI ---
SICREDI_ENVIRONMENT=production
SICREDI_CLIENT_ID=
SICREDI_CLIENT_SECRET=

# --- Mercado Pago ---
MERCADO_PAGO_ACCESS_TOKEN=

# --- Frontend (embutido no build Docker) ---
NEXT_PUBLIC_API_URL=https://api.app.oticasqueiroz.com.br

# --- Traefik (nome da rede externa já existente no VPS) ---
TRAEFIK_NETWORK=traefik-public
