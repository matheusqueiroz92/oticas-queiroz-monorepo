# ─── Aplicação ────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=3333

# ─── Banco de dados ───────────────────────────────────────────────────────────
# Formato: mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
# Em Atlas (produção), habilite replica set para suporte a transações
MONGODB_URI=mongodb://localhost:27017/oticas-queiroz

# ─── Autenticação ─────────────────────────────────────────────────────────────
# Mínimo 32 caracteres aleatórios em produção (ex: openssl rand -hex 32)
JWT_SECRET=troque-por-string-aleatoria-longa-em-producao
JWT_EXPIRES_IN=24h            # Tempo de expiração do access token

# ─── URLs ─────────────────────────────────────────────────────────────────────
# URL pública do frontend (usada em links de e-mail de reset de senha)
FRONTEND_URL=http://localhost:3000
# URL pública da API (usada no Swagger e em respostas de URL de imagem)
API_URL=http://localhost:3333

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# Necessário para recuperação de senha
EMAIL_HOST=smtp.exemplo.com
EMAIL_PORT=587
EMAIL_SECURE=false            # true para porta 465
EMAIL_USER=seu-email@exemplo.com
EMAIL_PASS=sua-senha-de-app
EMAIL_FROM=noreply@oticasqueiroz.com.br

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info                # error | warn | info | debug

# ─── Swagger ──────────────────────────────────────────────────────────────────
# Em produção, deixe SWAGGER_ENABLED=false ou proteja com SWAGGER_SECRET
SWAGGER_ENABLED=true
# Chave de acesso ao Swagger em produção: GET /api-docs?key=SWAGGER_SECRET
SWAGGER_SECRET=

# ─── Sicredi (boleto bancário) ────────────────────────────────────────────────
SICREDI_ENVIRONMENT=homologation    # homologation | production
SICREDI_CLIENT_ID=
SICREDI_CLIENT_SECRET=
SICREDI_COOPERATIVE_CODE=
SICREDI_POST_CODE=
SICREDI_ACCESS_CODE=
SICREDI_ACCESS_TOKEN=

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
