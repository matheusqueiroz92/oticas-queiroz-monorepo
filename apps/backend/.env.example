# ─── Aplicação ────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=3333

# ─── Banco de dados ───────────────────────────────────────────────────────────
# PRODUÇÃO: use a URI do servidor/VPN (não commitar). Ex.: mongodb://user:pass@host:27017/...
#
# DESENVOLVIMENTO LOCAL (Mongo via Docker na raiz do monorepo):
#   1. cp .env.docker.dev.example .env.docker.dev
#   2. npm run docker:dev:mongo   (na raiz do monorepo)
#   3. Ajuste MONGODB_URI abaixo com o mesmo usuário/senha de .env.docker.dev
MONGODB_URI=mongodb://admin:oticas_dev_local@127.0.0.1:27018/oticas-queiroz?authSource=admin&replicaSet=rs0&directConnection=true

# ─── Autenticação ─────────────────────────────────────────────────────────────
# Mínimo 32 caracteres aleatórios em produção (ex: openssl rand -hex 32)
JWT_SECRET=troque-por-string-aleatoria-longa-em-producao
JWT_EXPIRES_IN=24h            # Tempo de expiração do access token

# ─── API Bot (n8n / WhatsApp) ────────────────────────────────────────────────
# Chave enviada no header x-api-key nas rotas /api/bot/* (use valor longo e aleatório em produção)
BOT_API_KEY=
# TTL da sessão do chatbot WhatsApp (minutos sem interação; padrão 30)
BOT_SESSION_TTL_MINUTES=30
# Valor exibido no agendamento de exame (opção 3 do menu)
BOT_EXAM_PRICE_BRL=150
# Monitor proativo de inatividade (envia aviso e encerra conversa sem nova mensagem do cliente)
BOT_INACTIVITY_WARNING_MINUTES=10
BOT_INACTIVITY_CLOSE_MINUTES=5
BOT_INACTIVITY_POLL_INTERVAL_SECONDS=60
BOT_INACTIVITY_MONITOR_ENABLED=true
# URL do gateway WhatsApp para envio proativo (POST /send-message)
WHATSAPP_BOT_URL=http://localhost:3344

# ─── URLs ─────────────────────────────────────────────────────────────────────
# URL pública do frontend (usada em links de e-mail de reset de senha)
FRONTEND_URL=http://localhost:3000
# URL pública da API (usada no Swagger e em respostas de URL de imagem)
API_URL=http://localhost:3333

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# Necessário para recuperação de senha
EMAIL_HOST=smtp.exemplo.com
EMAIL_PORT=587
EMAIL_SECURE=false            # true para porta 465
EMAIL_USER=seu-email@exemplo.com
EMAIL_PASS=sua-senha-de-app
EMAIL_FROM=noreply@oticasqueiroz.com.br

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info                # error | warn | info | debug

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Limites aplicados POR IP. Lojas/escritórios atrás de um mesmo NAT compartilham
# o IP público — por isso os defaults são bem mais altos que um "single user".
# Para desativar completamente em emergências: RATE_LIMIT_DISABLED=true
RATE_LIMIT_DISABLED=false
# Global (toda /api). Padrão: 1000 req/minuto.
RATE_LIMIT_GLOBAL_MAX=1000
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
# Login. Chave = IP + login (cada par tem sua própria contagem).
# Padrão: 20 tentativas em 15 min por (IP, login).
RATE_LIMIT_LOGIN_MAX=20
RATE_LIMIT_LOGIN_WINDOW_MS=900000
# Refresh token. Padrão: 60 / 15 min por IP.
RATE_LIMIT_REFRESH_MAX=60
RATE_LIMIT_REFRESH_WINDOW_MS=900000
# Forgot password. Padrão: 10 / 15 min por IP.
RATE_LIMIT_FORGOT_MAX=10
RATE_LIMIT_FORGOT_WINDOW_MS=900000
# Reset password / validate token. Padrão: 10 / 15 min por IP.
RATE_LIMIT_RESET_MAX=10
RATE_LIMIT_RESET_WINDOW_MS=900000
# Bot WhatsApp (chave = remoteJid). Padrão: 30 / 1 min por usuário.
RATE_LIMIT_BOT_MAX=30
RATE_LIMIT_BOT_WINDOW_MS=60000

# ─── Swagger ──────────────────────────────────────────────────────────────────
# Em produção, deixe SWAGGER_ENABLED=false ou proteja com SWAGGER_SECRET
SWAGGER_ENABLED=true
# Chave de acesso ao Swagger em produção: GET /api-docs?key=SWAGGER_SECRET
SWAGGER_SECRET=

# ─── Sicredi (boleto bancário — API Cobrança v3.8) ───────────────────────────
# ATENÇÃO: homologation (/sb/) e production usam credenciais DIFERENTES.
#
# HOMOLOGAÇÃO (testes — boletos fictícios):
#   SICREDI_API_KEY = Token de Acesso do app *Sandbox* (portal → Minhas Apps → detalhes)
#   SICREDI_BENEFICIARY_CODE=12345  SICREDI_COOPERATIVE_CODE=6789  SICREDI_ACCESS_CODE=teste123
#   (username OAuth = 123456789)
#
# PRODUÇÃO (boletos reais — OTICAS G QUEIROZ):
#   SICREDI_ENVIRONMENT=production
#   SICREDI_API_KEY = Token de Acesso do app *Produção* (NÃO use o token do Sandbox)
#   SICREDI_BENEFICIARY_CODE / COOPERATIVE / POST = Internet Banking (ex.: 27391, 2103, 06)
#   SICREDI_ACCESS_CODE = Código de Acesso gerado no Internet Banking → Cobrança (~64 caracteres).
#     Credencial *permanente*: só troca quando você altera no IB ou cai numa política
#     de renovação de senha do banco. O backend cuida sozinho do token OAuth (renova
#     access_token/refresh_token a cada requisição).
#   Client ID / Client Secret do portal NÃO entram no OAuth desta API.
#
# OAuth: username = SICREDI_BENEFICIARY_CODE + SICREDI_COOPERATIVE_CODE (9 caracteres).
SICREDI_ENVIRONMENT=homologation    # homologation | production
SICREDI_API_KEY=                    # Token de Acesso (UUID) do app correspondente ao ambiente
SICREDI_ACCESS_CODE=                # Homolog: teste123 | Produção: código do Internet Banking
SICREDI_BENEFICIARY_CODE=           # Homolog: 12345 | Produção: ex. 27391
SICREDI_COOPERATIVE_CODE=           # Homolog: 6789 | Produção: ex. 2103
SICREDI_POST_CODE=                  # ex. 06
SICREDI_AUTO_SYNC=false             # true | false
SICREDI_SYNC_INTERVAL=30            # minutos
SICREDI_TIPO_COBRANCA=NORMAL        # NORMAL | HIBRIDO
# Teste local: npx ts-node scripts/dev/test-sicredi-auth.ts
# API: GET /api/sicredi/test-connection (com JWT)

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
